# 银河证券管理系统 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ========================
# Supabase 核心配置 (前端必需)
# ========================

# Supabase 项目 URL
# 获取方式: Supabase Dashboard > Project Settings > General > Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase 匿名密钥 (前端使用，公开安全)
# 获取方式: Supabase Dashboard > Project Settings > API > Project API keys > anon public
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Edge Function URL
# 格式: https://your-project-ref.supabase.co/functions/v1
VITE_SUPABASE_FUNCTION_URL=https://your-project-ref.supabase.co/functions/v1

# ========================
# 服务端配置 (不要暴露给前端)
# ========================

# Supabase 服务角色密钥 (仅后端/脚本使用)
# 获取方式: Supabase Dashboard > Project Settings > API > Project API keys > service_role secret
# ⚠️ 注意: 此密钥具有完全权限，不要暴露给客户端!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Secret (用于验证 token)
# 获取方式: Supabase Dashboard > Project Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ========================
# 数据库连接 (开发脚本使用)
# ========================

# 数据库连接池 URL (推荐)
# 获取方式: Supabase Dashboard > Project Settings > Database > Connection string > URI > Transaction pooler
DATABASE_URL=postgres://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:6543/postgres?sslmode=require

# 数据库直连 URL (用于迁移)
# 获取方式: Supabase Dashboard > Project Settings > Database > Connection string > URI > Direct connection
DATABASE_URL_NON_POOLING=postgres://postgres.[project-ref]:[password]@aws-1-[region].pooler.supabase.com:5432/postgres?sslmode=require

# ========================
# 对象存储配置 (可选)
# ========================

# 存储桶端点
COZE_BUCKET_ENDPOINT_URL=https://your-project-ref.supabase.co/storage/v1
COZE_BUCKET_NAME=default

# ========================
# 业务功能配置
# ========================

# 是否使用真实市场数据
VITE_USE_REAL_MARKET_DATA=true

# QOS API 密钥 (大宗交易数据)
VITE_QOS_KEY=your-qos-key-here

# QOS 产品列表
VITE_QOS_PRODUCTS=XAUUSD,XAGUSD,600519

# ========================
# 安全配置
# ========================

# 环境标识
ENVIRONMENT=development

# 管理端IP白名单 (生产环境必须配置)
ADMIN_ALLOWED_IPS=your-ip-address

# ========================
# 获取环境变量的完整步骤
# ========================

# 1. 登录 Supabase Dashboard
#    https://supabase.com/dashboard

# 2. 选择你的项目

# 3. 获取项目 URL 和 API 密钥
#    Project Settings > API
#    - URL: Project URL (VITE_SUPABASE_URL)
#    - anon public: 匿名密钥 (VITE_SUPABASE_ANON_KEY)
#    - service_role secret: 服务角色密钥 (SUPABASE_SERVICE_ROLE_KEY)
#    - JWT Secret: JWT 密钥 (SUPABASE_JWT_SECRET)

# 4. 获取数据库连接字符串
#    Project Settings > Database > Connection string
#    - Transaction pooler: 连接池 URL (DATABASE_URL)
#    - Direct connection: 直连 URL (DATABASE_URL_NON_POOLING)
#    注意: 需要先设置数据库密码

# 5. 设置数据库密码 (如果还没设置)
#    Project Settings > Database > Database Password
#    点击 "Reset database password" 设置新密码

# ========================
# Vercel 部署配置
# ========================
# 在 Vercel 控制台 > Settings > Environment Variables 添加:
#
# Production 环境:
# - VITE_SUPABASE_URL
# - VITE_SUPABASE_ANON_KEY
# - VITE_SUPABASE_FUNCTION_URL
# - SUPABASE_SERVICE_ROLE_KEY (保密!)
# - SUPABASE_JWT_SECRET (保密!)
# - ENVIRONMENT=production
# - ADMIN_ALLOWED_IPS
#
# Preview 和 Development 环境同样配置
