# 银河证券管理系统 - 环境变量配置
# 复制此文件为 .env 并填入实际值

# ========================
# Supabase 配置 (Vite 客户端)
# ========================

# Supabase 项目 URL (必需)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase 匿名密钥 (客户端使用，必需)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Edge Function URL (可选，用于admin-verify等函数)
# 格式：https://[project-ref].functions.supabase.co 或 ${VITE_SUPABASE_URL}/functions/v1
VITE_SUPABASE_FUNCTION_URL=https://your-project-ref.functions.supabase.co

# ========================
# 服务器端配置 (不在客户端暴露)
# ========================

# Supabase 服务角色密钥 (仅服务器端使用)
# 注意：不要在客户端暴露此密钥！
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ========================
# 数据库连接 (可选，用于脚本)
# ========================

# 数据库连接字符串 (用于开发脚本)
DATABASE_URL=postgres://user:password@host:port/database

# ========================
# 业务功能配置
# ========================

# 是否使用真实市场数据 (true/false)
VITE_USE_REAL_MARKET_DATA=true

# QOS API 密钥 (大宗交易数据)
VITE_QOS_KEY=your-qos-key-here

# QOS 产品列表
VITE_QOS_PRODUCTS=XAUUSD,XAGUSD,600519

# ========================
# 安全配置
# ========================

# 管理员IP白名单 (Edge Function使用，支持IP段)
# 格式：用逗号分隔的IP地址或IP段，如：192.168.1.100,10.0.,172.16.
# 注意：已重构为使用ADMIN_ALLOWED_IPS环境变量
ADMIN_IP_WHITELIST=127.0.0.1,::1,192.168.,10.,172.16.,172.17.,172.18.,172.19.,172.20.,172.21.,172.22.,172.23.,172.24.,172.25.,172.26.,172.27.,172.28.,172.29.,172.30.,172.31.

# 管理员IP白名单 (新版本，Edge Function admin-verify使用)
# 格式：用逗号分隔的IP地址，如：103.136.110.139,192.168.1.100,10.0.0.0/8
ADMIN_ALLOWED_IPS=103.136.110.139,192.168.1.100,10.0.0.0/8

# ========================
# Vercel 部署说明
# ========================

# 在 Vercel 控制台设置以下环境变量：
# 1. VITE_SUPABASE_URL = 你的 Supabase 项目 URL
# 2. VITE_SUPABASE_ANON_KEY = 你的 Supabase 匿名密钥
# 3. SUPABASE_SERVICE_ROLE_KEY = 你的 Supabase 服务角色密钥 (仅服务器端)
# 4. ADMIN_ALLOWED_IPS = 管理员IP白名单 (生产环境必须配置，Edge Function admin-verify使用)
# 5. ADMIN_IP_WHITELIST = 管理员IP白名单 (旧版本，兼容性保留)

# 注意：
# - Vite 只暴露 VITE_ 前缀的环境变量到客户端
# - 不要将服务角色密钥暴露给客户端
# - 在 Vercel 中为所有环境（生产、预览、开发）设置这些变量
# - 生产环境必须配置ADMIN_ALLOWED_IPS，只允许公司内部IP访问管理后台
# - IPO数据已下沉至Supabase数据库，不再使用外部新浪API