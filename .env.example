# ============================================
# 环境变量配置指南
# ============================================
# 本项目使用 Supabase Edge Functions 作为后端
# 前端部署在 Vercel，后端是 Supabase 托管
#
# 配置位置：
# - 前端环境变量 (Vercel Dashboard): 以 VITE_ 开头的变量
# - 后端环境变量 (Supabase Dashboard): Edge Functions 需要的变量
# ============================================

# ============================================
# 1. 前端环境变量 (配置在 Vercel Dashboard)
# ============================================
# 这些变量以 VITE_ 开头，Vite 会自动暴露给前端代码
# 配置路径: Vercel Project → Settings → Environment Variables

# Supabase 核心配置 (必需)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# 银禾数据 Edge Function
VITE_YINHE_FUNCTION_URL=https://your-project.supabase.co/functions/v1/yinhe-data

# 手机号归属地 Edge Function
VITE_PHONE_LOCATION_FUNCTION_URL=https://your-project.supabase.co/functions/v1/phone-location

# ============================================
# 2. 后端环境变量 (配置在 Supabase Dashboard)
# ============================================
# 这些变量用于 Edge Functions，在 Supabase 后台配置
# 配置路径: Supabase Project → Settings → Edge Functions

# Supabase 服务密钥 (用于后端操作，如数据库同步)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# IPO 同步 API 密钥 (用于 Edge Function 身份验证)
IPO_SYNC_API_KEY=your-ipo-sync-api-key-here

# 外部 API 密钥
QVERIS_API_KEY=your-qveris-api-key-here

# 银禾数据 API Key (在 Supabase Secrets 中配置)
# supabase secrets set YINHE_API_KEY=your_key_here

# 手机号归属地 API Keys (在 Supabase Secrets 中配置)
# supabase secrets set JUHE_PHONE_API_KEY=your_key_here
# supabase secrets set SHOWAPI_APPID=your_appid_here
# supabase secrets set SHOWAPI_SECRET=your_secret_here

# ============================================
# 3. 图片资源 URL 配置 (前端环境变量)
# ============================================
# 所有图片 URL 应该指向你的 Supabase Storage 中的资源
# 配置方式有两种：
#
# 方式1：使用 Storage URL 工具函数 (推荐)
# 在 lib/imageUtils.ts 中使用 getImageUrl() 函数
# 只需要配置基础 Storage 配置，图片路径会自动拼接
#
# 方式2：直接配置完整 URL
# 如果你有特殊的图片存储位置，可以直接配置完整 URL

# --------------------------------------------
# 3.1 Storage 基础配置 (方式1 - 推荐)
# --------------------------------------------
# 存储桶名称 (默认: public)
VITE_STORAGE_BUCKET=public

# 图片文件夹路径 (默认: images)
VITE_STORAGE_FOLDER=images

# --------------------------------------------
# 3.2 直接配置完整 URL (方式2 - 可选)
# --------------------------------------------
# 如果配置了以下完整 URL，将优先使用这些值
# 否则会自动从 Storage 拼接 URL

# Logo 和聊天组件
VITE_LOGO_URL=/logo.png
VITE_AGENT_AVATAR_URL=/avatar-default.png
VITE_ADMIN_LOGO_URL=/logo.png

# 训练营地背景图
VITE_TRAINING_BG_1=/images/training-bg-1.png
VITE_TRAINING_BG_2=/images/training-bg-2.png
VITE_TRAINING_LOGO=/logo.png

# 首页轮播图
VITE_CAROUSEL_IMAGE_1=/images/carousel-1.jpg
VITE_CAROUSEL_IMAGE_2=/images/carousel-2.png
VITE_CAROUSEL_IMAGE_3=/images/carousel-3.png

# 首页服务图标
VITE_SERVICE_ICON_1=/images/service-icon-1.png
VITE_SERVICE_ICON_2=/images/service-icon-2.png
VITE_SERVICE_ICON_3=/images/service-icon-3.png
VITE_SERVICE_ICON_4=/images/service-icon-4.png

# 背景图
VITE_BACKGROUND_IMAGE_1=/images/bg-1.png
VITE_BACKGROUND_IMAGE_2=/images/bg-2.png

# 研报图片
VITE_RESEARCH_IMAGE_1=/images/research-1.png

# 公章图片
VITE_SEAL_URL=/images/seal.png

# Banner 轮播图
VITE_BANNER_IMAGE_1=/images/banner-1.jpg
VITE_BANNER_IMAGE_2=/images/banner-2.jpg

# ============================================
# 4. 安全配置
# ============================================
# Vercel Cron Job 密钥 (可选)
VERCEL_CRON_SECRET=your-random-secret-here

# 管理员 IP 白名单 (可选)
ADMIN_IP_WHITELIST=""

# ============================================
# 配置检查清单
# ============================================
# [ ] 在 Vercel 配置了 VITE_SUPABASE_URL
# [ ] 在 Vercel 配置了 VITE_SUPABASE_ANON_KEY
# [ ] 在 Supabase 配置了 SUPABASE_SERVICE_ROLE_KEY (Edge Functions)
# [ ] 在 Supabase 配置了 IPO_SYNC_API_KEY (Edge Functions)
# [ ] 上传了图片资源到 Supabase Storage 或准备了本地占位图片
# [ ] 配置了 Vercel Cron Secret (如果使用自动同步)
