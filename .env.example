# ============================================
# 环境变量配置指南
# ============================================
# 本项目使用 Supabase 作为后端服务
# 前端部署在 Vercel，后端是 Supabase 托管
#
# 行情数据：东方财富免费API + Redis缓存（轻量化方案）
# ============================================

# ============================================
# 1. Supabase 核心配置（必需）
# ============================================
# 这些变量以 VITE_ 开头，Vite 会自动暴露给前端代码
# 配置路径: Vercel Project → Settings → Environment Variables

# Supabase 项目 URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key（公开密钥，用于客户端访问）
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Publishable Key（新格式的公开密钥）
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# ============================================
# 2. 行情数据配置
# ============================================
# 是否使用真实行情数据（true/false）
VITE_USE_REAL_MARKET_DATA=true

# 数据源：东方财富免费API（通过 proxy-market Edge Function 代理）
# 支持市场：A股、港股、美股、北交所、科创板
# 无需额外配置，开箱即用

# ============================================
# 3. Edge Functions 配置
# ============================================
# 这些变量用于 Edge Functions，在 Supabase 后台配置
# 配置路径: Supabase Project → Settings → Edge Functions

# Supabase 项目 URL（后端使用）
SUPABASE_URL=https://your-project.supabase.co

# IPO 同步 API 密钥
IPO_SYNC_API_KEY=your-ipo-sync-api-key-here

# ============================================
# 4. Upstash Redis 缓存配置
# ============================================
# Redis 缓存用于行情数据和涨停板监控

# Upstash Redis REST URL
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io

# Upstash Redis REST Token
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ============================================
# 5. 安全配置
# ============================================
# 管理员 IP 白名单（多个 IP 用逗号分隔）
ADMIN_IP_WHITELIST=""

# ============================================
# 配置检查清单
# ============================================
# [ ] 在 Vercel 配置了 VITE_SUPABASE_URL
# [ ] 在 Vercel 配置了 VITE_SUPABASE_ANON_KEY
# [ ] 在 Vercel 配置了 VITE_SUPABASE_PUBLISHABLE_KEY
# [ ] 在 Supabase 配置了 UPSTASH_REDIS_REST_URL
# [ ] 在 Supabase 配置了 UPSTASH_REDIS_REST_TOKEN
# [ ] 在 Supabase 配置了 IPO_SYNC_API_KEY（如需 IPO 同步）

# ============================================
# 获取 Supabase 配置信息
# ============================================
# 1. 登录 Supabase Dashboard: https://supabase.com
# 2. 选择你的项目
# 3. 进入 Settings → API
# 4. 复制以下信息：
#    - Project URL → VITE_SUPABASE_URL
#    - Anon Key (Legacy) → VITE_SUPABASE_ANON_KEY
#    - Publishable Key → VITE_SUPABASE_PUBLISHABLE_KEY
