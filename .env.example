# ========================
# Supabase 核心配置 (Vercel 部署必需)
# ========================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SUPABASE_FUNCTION_URL=https://your-project.supabase.co/functions/v1

# ========================
# 银禾数据库数据源 (免费数据源)
# ========================
# 安装: pip install yinhedata
# 启动服务: cd api && python yinhedata_service.py
VITE_YINHE_API_URL=http://localhost:8080

# ========================
# Supabase Edge Functions 配置 (部署到 Supabase 时使用)
# ========================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
IPO_SYNC_API_KEY=your-ipo-sync-api-key-here
QVERIS_API_KEY=your-qveris-api-key-here

# ========================
# 安全配置
# ====================
ADMIN_IP_WHITELIST="103.136.110.139"
